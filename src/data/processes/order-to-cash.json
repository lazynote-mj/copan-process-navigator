{
  "id": "order-to-cash",
  "name": "Order to Cash (주문~수금)",
  "description": "고객 주문 접수부터 출하, 송장 발행, 수금까지의 Copan ERP TO-BE 프로세스",
  "version": "TO-BE v1.0",
  "status": "approved",
  "lastModified": "2026-06-15",
  "owner": "ERP PMO",
  "phases": [
    { "id": "order-entry", "label": "주문 접수", "order": 1 },
    { "id": "credit-check", "label": "신용/승인", "order": 2 },
    { "id": "fulfillment", "label": "출하", "order": 3 },
    { "id": "billing", "label": "청구", "order": 4 },
    { "id": "payment", "label": "수금", "order": 5 }
  ],
  "lanes": [
    {
      "id": "lane-sales",
      "name": "영업",
      "order": 1,
      "ownerDepartment": "영업팀"
    },
    {
      "id": "lane-logistics",
      "name": "물류",
      "order": 2,
      "ownerDepartment": "물류팀"
    },
    {
      "id": "lane-finance",
      "name": "재무",
      "order": 3,
      "ownerDepartment": "재무팀"
    },
    {
      "id": "lane-erp",
      "name": "ERP 시스템",
      "order": 4,
      "ownerDepartment": "IT/ERP 운영"
    }
  ],
  "nodes": [
    {
      "id": "n01",
      "name": "주문 접수",
      "type": "process",
      "laneId": "lane-sales",
      "phaseId": "order-entry",
      "system": "SAP SD",
      "owner": "영업 담당자",
      "description": "고객 PO 또는 내부 판매오더를 ERP에 등록하고 납기·가격·품목을 확인합니다.",
      "inputs": ["고객 PO", "견적서", "판매계약"],
      "outputs": ["판매오더(SO)"],
      "controls": ["판매오더 생성 권한", "가격결정 절차", "고객 마스터 유효성"]
    },
    {
      "id": "n02",
      "name": "주문 유효성 검증",
      "type": "system",
      "laneId": "lane-erp",
      "phaseId": "order-entry",
      "system": "SAP SD",
      "owner": "ERP 시스템",
      "description": "품목 가용성, 납기, 가격, 세금코드 등 주문 정보를 자동 검증합니다.",
      "inputs": ["판매오더(SO)"],
      "outputs": ["검증 완료 SO", "오류 메시지"],
      "controls": ["품목 마스터", "가격 조건", "납기 규칙"]
    },
    {
      "id": "n03",
      "name": "신용한도 확인",
      "type": "decision",
      "laneId": "lane-erp",
      "phaseId": "credit-check",
      "system": "SAP FI/SD",
      "owner": "ERP 시스템",
      "description": "고객 신용한도와 미수금 잔액을 확인하여 출하 승인 여부를 판단합니다.",
      "inputs": ["검증 완료 SO", "고객 신용정보"],
      "outputs": ["출하 승인", "출하 보류"],
      "controls": ["신용한도 정책", "여신관리 기준"]
    },
    {
      "id": "n04",
      "name": "신용 승인",
      "type": "approval",
      "laneId": "lane-finance",
      "phaseId": "credit-check",
      "system": "SAP FI",
      "owner": "재무 팀장",
      "description": "신용한도 초과 건에 대해 예외 승인 여부를 검토합니다.",
      "inputs": ["출하 보류 SO", "신용 검토 요청"],
      "outputs": ["예외 승인", "승인 거부"],
      "controls": ["여신 승인 권한", "승인 한도 매트릭스"]
    },
    {
      "id": "n05",
      "name": "출하 지시",
      "type": "process",
      "laneId": "lane-logistics",
      "phaseId": "fulfillment",
      "system": "SAP SD/MM",
      "owner": "물류 담당자",
      "description": "출하 지시서를 확인하고 피킹·포장 작업을 시작합니다.",
      "inputs": ["출하 승인 SO", "출하 지시서"],
      "outputs": ["피킹 리스트", "출하 예정 정보"],
      "controls": ["출하 창고 지정", "배송 경로 규칙"]
    },
    {
      "id": "n06",
      "name": "출하 처리",
      "type": "process",
      "laneId": "lane-logistics",
      "phaseId": "fulfillment",
      "system": "SAP MM/SD",
      "owner": "물류 담당자",
      "description": "출하 완료 후 Goods Issue를 전기하고 배송 정보를 갱신합니다.",
      "inputs": ["피킹 리스트", "출하 실적"],
      "outputs": ["출하 전표(GI)", "운송장 정보"],
      "controls": ["재고 수불 기준", "출하 전 검수 절차"]
    },
    {
      "id": "n07",
      "name": "송장 발행",
      "type": "process",
      "laneId": "lane-finance",
      "phaseId": "billing",
      "system": "SAP SD/FI",
      "owner": "재무 담당자",
      "description": "출하 기준으로 세금계산서 및 고객 송장을 발행합니다.",
      "inputs": ["출하 전표(GI)", "가격/세금 정보"],
      "outputs": ["고객 송장", "세금계산서"],
      "controls": ["청구 시점 정책", "세금코드 규정"]
    },
    {
      "id": "n08",
      "name": "매출 전표 생성",
      "type": "system",
      "laneId": "lane-erp",
      "phaseId": "billing",
      "system": "SAP FI",
      "owner": "ERP 시스템",
      "description": "송장 정보를 기반으로 매출 전표를 자동 생성합니다.",
      "inputs": ["고객 송장"],
      "outputs": ["매출 전표", "채권 항목"],
      "controls": ["계정 결정 규칙", "전기 기간 통제"]
    },
    {
      "id": "n09",
      "name": "수금 등록",
      "type": "process",
      "laneId": "lane-finance",
      "phaseId": "payment",
      "system": "SAP FI",
      "owner": "재무 담당자",
      "description": "고객 입금을 확인하고 수금을 등록하여 미수금을 정리합니다.",
      "inputs": ["입금 내역", "채권 항목"],
      "outputs": ["수금 전표", "채권 정리 결과"],
      "controls": ["수금 매칭 규칙", "입금 확인 절차"]
    },
    {
      "id": "n10",
      "name": "주문 보류 협의",
      "type": "process",
      "laneId": "lane-sales",
      "phaseId": "credit-check",
      "system": "SAP SD",
      "owner": "영업 담당자",
      "description": "신용한도 초과 시 고객과 납기·결제 조건을 협의하고 재요청합니다.",
      "inputs": ["출하 보류 SO"],
      "outputs": ["수정 SO", "재검토 요청"],
      "controls": ["주문 변경 권한", "할인/조건 변경 정책"]
    }
  ],
  "edges": [
    { "id": "e01", "source": "n01", "target": "n02", "condition": "", "label": "" },
    { "id": "e02", "source": "n02", "target": "n03", "condition": "", "label": "" },
    {
      "id": "e03",
      "source": "n03",
      "target": "n05",
      "condition": "approved",
      "label": "승인"
    },
    {
      "id": "e04",
      "source": "n03",
      "target": "n10",
      "condition": "creditExceeded",
      "label": "한도 초과"
    },
    {
      "id": "e05",
      "source": "n10",
      "target": "n04",
      "condition": "escalated",
      "label": "재무 승인 요청"
    },
    {
      "id": "e06",
      "source": "n04",
      "target": "n03",
      "condition": "reReview",
      "label": "재검토"
    },
    {
      "id": "e07",
      "source": "n04",
      "target": "n05",
      "condition": "exceptionApproved",
      "label": "예외 승인"
    },
    { "id": "e08", "source": "n05", "target": "n06", "condition": "", "label": "" },
    { "id": "e09", "source": "n06", "target": "n07", "condition": "", "label": "" },
    { "id": "e10", "source": "n07", "target": "n08", "condition": "", "label": "" },
    { "id": "e11", "source": "n08", "target": "n09", "condition": "", "label": "" }
  ]
}
